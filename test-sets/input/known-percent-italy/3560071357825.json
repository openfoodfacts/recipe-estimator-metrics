    "ingredients_text": "Farine de maïs 75%, huile de tournesol 20%, préparation aromatisante goût chili 5% (sel, maltodextrine, piment en poudre, oignon séché, ail en poudre, arôme naturel).\nPeut contenir des traces de soja.",
    "ingredients_text_en": "Corn flour 75%, sunflower oil 20%, chili flavouring preparation 5% (salt, maltodextrin, chili powder, dried onion, garlic powder, natural flavouring).\nMay contain traces of soybeans.",
    "ingredients_text_en_imported": "Corn flour 75%, sunflower oil 20%, chili flavouring preparation 5% (salt, maltodextrin, chili powder, dried onion, garlic powder, natural flavouring).\nMay contain traces of soybeans.",
    "ingredients_text_fr": "Farine de maïs 75%, huile de tournesol 20%, préparation aromatisante goût chili 5% (sel, maltodextrine, piment en poudre, oignon séché, ail en poudre, arôme naturel).\nPeut contenir des traces de soja.",
    "ingredients_text_fr_imported": "Farine de maïs 75%, huile de tournesol 20%, préparation aromatisante goût chili 5% (sel, maltodextrine, piment en poudre, oignon séché, ail en poudre, arôme naturel).\nPeut contenir des traces de soja.",
    "ingredients_text_it": "Farina di mais 75%, olio di semi di girasole 20%, preparazione aromatizzante gusto chili 5% (sale, maltodestrina, peperoncino in polvere, cipolla essiccata, aglio in polvere, aroma naturale).\nPuò contenere soia.",
    "ingredients_text_it_imported": "Farina di mais 75%, olio di semi di girasole 20%, preparazione aromatizzante gusto chili 5% (sale, maltodestrina, peperoncino in polvere, cipolla essiccata, aglio in polvere, aroma naturale).\nPuò contenere soia.",
    "ingredients_text_pl": "Mąka kukurydziana 75%, olej słonecznikowy 20%, preparat aromatyczny o smaku chili 5% (sól, maltodekstryna, chili w proszku, suszona cebula, czosnek w proszku, aromat naturalny).\nMoże zawierać soję.",
    "ingredients_text_pl_imported": "Mąka kukurydziana 75%, olej słonecznikowy 20%, preparat aromatyczny o smaku chili 5% (sól, maltodekstryna, chili w proszku, suszona cebula, czosnek w proszku, aromat naturalny).\nMoże zawierać soję.",
    "ingredients_text_ro": "Făină de porumb 75%, ulei de floarea-soarelui 20%, preparat aromatizat cu aromă de ardei iute chilli 5% (sare, maltodextrină, ardei iute chilli pudră, ceapă deshidratată, usturoi pudră, aromă naturală). Poate conține urme de soia.",
    "ingredients_text_ro_imported": "Făină de porumb 75%, ulei de floarea-soarelui 20%, preparat aromatizat cu aromă de ardei iute chilli 5% (sare, maltodextrină, ardei iute chilli pudră, ceapă deshidratată, usturoi pudră, aromă naturală). Poate conține urme de soia.",
    "ingredients_text_with_allergens": "Farine de maïs 75%, huile de tournesol 20%, préparation aromatisante goût chili 5% (sel, maltodextrine, piment en poudre, oignon séché, ail en poudre, arôme naturel).\nPeut contenir des traces de <span class=\"allergen\">soja</span>.",
    "ingredients_text_with_allergens_en": "Corn flour 75%, sunflower oil 20%, chili flavouring preparation 5% (salt, maltodextrin, chili powder, dried onion, garlic powder, natural flavouring).\nMay contain traces of <span class=\"allergen\">soybeans</span>.",
    "ingredients_text_with_allergens_fr": "Farine de maïs 75%, huile de tournesol 20%, préparation aromatisante goût chili 5% (sel, maltodextrine, piment en poudre, oignon séché, ail en poudre, arôme naturel).\nPeut contenir des traces de <span class=\"allergen\">soja</span>.",
    "ingredients_text_with_allergens_it": "Farina di mais 75%, olio di semi di girasole 20%, preparazione aromatizzante gusto chili 5% (sale, maltodestrina, peperoncino in polvere, cipolla essiccata, aglio in polvere, aroma naturale).\nPuò contenere <span class=\"allergen\">soia</span>.",
    "ingredients_text_with_allergens_pl": "Mąka kukurydziana 75%, olej słonecznikowy 20%, preparat aromatyczny o smaku chili 5% (sól, maltodekstryna, chili w proszku, suszona cebula, czosnek w proszku, aromat naturalny).\nMoże zawierać<span class=\"allergen\"> soję</span>.",
    "ingredients_text_with_allergens_ro": "Făină de porumb 75%, ulei de floarea-soarelui 20%, preparat aromatizat cu aromă de ardei iute chilli 5% (sare, maltodextrină, ardei iute chilli pudră, ceapă deshidratată, usturoi pudră, aromă naturală). Poate conține urme de<span class=\"allergen\"> soia</span>.",
