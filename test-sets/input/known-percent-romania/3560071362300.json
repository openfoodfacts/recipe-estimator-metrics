    "ingredients_text_with_allergens": "<span class=\"allergen\">Cacahuètes</span> (<span class=\"allergen\">arachides</span>) 38,8%, raisins secs 19,9%, <span class=\"allergen\">amandes</span> 19.6%, <span class=\"allergen\">noix de cajou</span> 19,4%, huile de tournesol 2,3%.\nPeut contenir des traces de <span class=\"allergen\">gluten</span> et autres <span class=\"allergen\">fruits à coque</span>.",
    "ingredients_text_with_allergens_en": "<span class=\"allergen\">Peanuts</span> 38.8%, raisins 19.9%, <span class=\"allergen\">almonds</span> 19.6%, <span class=\"allergen\">cashews</span> 19.4%, sunflower oil 2.3%.\nMay contain traces of <span class=\"allergen\">cereals containing gluten</span> and other <span class=\"allergen\">nuts</span>.",
    "ingredients_text_with_allergens_fr": "<span class=\"allergen\">Cacahuètes</span> (<span class=\"allergen\">arachides</span>) 38,8%, raisins secs 19,9%, <span class=\"allergen\">amandes</span> 19.6%, <span class=\"allergen\">noix de cajou</span> 19,4%, huile de tournesol 2,3%.\nPeut contenir des traces de <span class=\"allergen\">gluten</span> et autres <span class=\"allergen\">fruits à coque</span>.",
    "ingredients_text_with_allergens_ro": "<span class=\"allergen\">Arahide</span> 38,8%, stafide 19,9%, <span class=\"allergen\">migdale</span> 19,6%, <span class=\"allergen\">nuci Caju</span> 19,4%, ulei de floarea-soarelui 2,3%. \nPoate conține urme de cereale care conțin gluten și de alte fructe cu coajă lemnoasă.",
